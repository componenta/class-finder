{
    "name": "componenta/class-finder",
    "description": "Lazy class discovery with composable filters and listener notification",
    "keywords": [
        "class-finder",
        "class-discovery",
        "php-reflection",
        "attribute-filter",
        "tokenizer",
        "autoloader",
        "psr-11"
    ],
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "symfony/finder": "^7.0 || ^8.0",
        "componenta/tokenizer": "^1.0",
        "componenta/arrayable": "^1.0",
        "componenta/config": "^1.0",
        "componenta/filter": "^1.0",
        "componenta/iterator": "^1.0",
        "psr/log": "^3.0",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Componenta\\ClassFinder\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Componenta\\ClassFinder\\Tests\\": "tests/"
        }
    },
    "extra": {
        "componenta": {
            "config-providers": [
                "Componenta\\ClassFinder\\ConfigProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable"
}
